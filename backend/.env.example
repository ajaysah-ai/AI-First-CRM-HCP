# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=qwen/qwen3.6-27b

# --- Database ---
# Postgres (recommended, e.g. Neon free tier):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/hcp_crm
# For quick local testing without Postgres, use SQLite instead:
DATABASE_URL=sqlite:///./hcp_crm.db

# --- App ---
CORS_ORIGINS=http://localhost:5173
ENV=development
